{
  "name": "token-profiler-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:contracts": "vitest run src/test/contract-fixtures.test.ts src/test/api-client.test.ts",
    "test:boundaries": "vitest run src/test/import-boundary.test.ts src/test/package-boundary.test.ts",
    "test:styles": "vitest run src/test/style-boundary.test.ts",
    "fixtures:capture": "tsx scripts/capture-api-fixtures.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.11",
    "typescript": "^5.7.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
